# ─── Igris Radar — Environment Variables ─────────────────────────────────────
# Copy this file to `.env.local` and fill in real values. Never commit secrets.

# ── Required ─────────────────────────────────────────────────────────────────
MONGO_URL=mongodb://localhost:27017
DB_NAME=igrisradar

# ── Session / crypto (SECURITY) ──────────────────────────────────────────────
# HMAC key that signs session + admin tokens. MUST be a strong random 32+ char
# string in production. Generate one with:  openssl rand -base64 48
SESSION_SECRET=change-me-generate-a-strong-32plus-char-random-string

# Master key for AES-256-GCM secret encryption (lib/crypto.js). 32+ chars.
ENCRYPTION_MASTER_KEY=change-me-32-char-minimum-random-key

# ── Admin panel (SECURITY C2) ────────────────────────────────────────────────
# The admin login endpoint is DISABLED unless both are set.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password_here

# ── Cron (SECURITY) ──────────────────────────────────────────────────────────
# Shared secret required to trigger /api?path=cron/run-scheduled-audits.
# Call with:  Authorization: Bearer <CRON_SECRET>   or   ?secret=<CRON_SECRET>
CRON_SECRET=

# ── Networking ───────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for CORS + CSRF origin checks.
CORS_ORIGINS=https://igrisradar.com
NEXT_PUBLIC_SITE_URL=https://igrisradar.com

# ── Optional integrations (features enable when key is present) ───────────────
# AI Providers
GEMINI_API_KEY=
Z_AI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=
PAGESPEED_API_KEY=

# ── Email delivery (Settings → Notifications) ────────────────────────────────
# Configure ONE of the two options below. When neither is set, emails are
# logged to the server console instead of being sent (dev fallback).
#
# Option A — SMTP (works with Gmail: host smtp.gmail.com, port 587, and an
# App Password from https://myaccount.google.com/apppasswords):
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
#
# Option B — Resend (https://resend.com, free tier):
RESEND_API_KEY=
#
# Sender shown on outgoing mail (for Gmail SMTP use your Gmail address):
EMAIL_FROM=Igris Radar <support@igrisecurity.com>

# ── Stripe billing (Legacy) ──────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Dodo Payments ────────────────────────────────────────────────────────────
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_WEBHOOK_KEY=
NEXT_PUBLIC_DODO_PRODUCT_STARTER=
NEXT_PUBLIC_DODO_PRODUCT_PRO=
# One-time payment product for unlocking a free-scanner report on the landing page
DODO_PRODUCT_UNLOCK_REPORT=

